# faceplica — instrumentum aedificandi pro κadc.
#
# Facies:
#   proba     — probationes currit (proba.κ et ὀμφαλός)
#   purga     — artificia removet

PYTHON ?= python3

omnia:
	@ echo nihil agendum

proba:
	$(PYTHON) proba.py proba.κ proba.κ.c99
	$(PYTHON) proba.py ὀμφαλός ὀμφαλός.c99

colloca:
	@ echo nihil collocandum

purga:
	rm -rf proba.κ.c99 ὀμφαλός.c99 ἔξοδος.bin __pycache__

.PHONY: omnia colloca proba purga
